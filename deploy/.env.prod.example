TZ=Asia/Shanghai

# 域名与 HTTPS
SITE_ADDRESS=sslovett.top
ACME_EMAIL=you@example.com

# MySQL
MYSQL_DATABASE=nexatalk
MYSQL_USER=nexatalk
MYSQL_PASSWORD=replace-with-strong-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

# 后端使用的数据库连接
DB_URL=jdbc:mysql://mysql:3306/nexatalk?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=nexatalk
DB_PASSWORD=replace-with-strong-mysql-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password

# JWT
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes

# AI 配置（不用可保留默认）
AI_ENABLED=false
AI_BASE_URL=https://api.openai.com
AI_API_KEY=
AI_MODEL=qwen3.5-plus
AI_TIMEOUT_MS=30000

# JVM 内存
JAVA_OPTS=-Xms256m -Xmx768m
